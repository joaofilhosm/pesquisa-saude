# ===========================================
# CONFIGURAÇÕES PARA API DE PESQUISA EM SAÚDE
# ===========================================

# --- Supabase (opcional) ---
# Crie um projeto em https://supabase.com e cole as credenciais abaixo
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-service-role

# --- API Keys de Acesso ---
# Separe múltiplas chaves por vírgula
API_KEYS=sk-pesquisa-saude-2026-master-key,sk-demo-key-12345

# --- Backend Python ---
PYTHON_HOST=0.0.0.0
PORT=8001

# --- NCBI API Key (PubMed - opcional mas recomendado) ---
# Sem API key: até 10 req/s
# Com API key (gratuita): taxa maior e acesso prioritário
# Obtenha em: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# --- Semantic Scholar API Key (opcional) ---
# Sem chave: ~1 req/s (suficiente para uso normal)
# Com chave (gratuita): ~10 req/s e maior estabilidade
# Obtenha em: https://www.semanticscholar.org/product/api
S2_API_KEY=

# OpenAlex não requer chave — 100% gratuito e aberto.
# Polite pool ativo automaticamente via User-Agent (mailto incluído no código).

# --- Google Scholar (scholarly + proxy SOCKS5) ---
# Sem GOOGLE_SCHOLAR_PROXY: fonte desabilitada (retorna lista vazia, sem erro).
# Com proxy configurado: scholarly usa o proxy SOCKS5 para acessar o Scholar.
# Use socks5:// ou socks5h:// (recomendado — DNS resolvido pelo proxy).
# Exemplo: socks5://127.0.0.1:1080
GOOGLE_SCHOLAR_PROXY=socks5://127.0.0.1:1080

# --- Google Scholar APIs Alternativas (opcionais) ---
# APIs pagas para acesso confiável ao Google Scholar sem bloqueios.
# Configure uma ou mais para redundância:
SERPAPI_KEY=           # https://serpapi.com/manage-api-key
SEARCHAPI_KEY=         # https://www.searchapi.io/api-key
SCHOLARAPI_KEY=        # https://scholarapi.net
SERPLY_API_KEY=        # https://serply.io

# --- Scrapers ---
# Timeout para requisições HTTP (segundos)
HTTP_TIMEOUT=30

# --- Cache ---
# O cache é em memória (TTL configurado no código):
# - cache_curto: 5 minutos
# - cache_medio: 1 hora (buscas)
# - cache_longo: 24 horas (listas estáticas como PCDTs)

