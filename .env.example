# ===========================================
# CONFIGURAÇÕES PARA API DE PESQUISA EM SAÚDE
# ===========================================

# --- Supabase (opcional) ---
# Crie um projeto em https://supabase.com e cole as credenciais abaixo
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-service-role

# --- API Keys de Acesso ---
# Separe múltiplas chaves por vírgula
API_KEYS=sk-pesquisa-saude-2026-master-key,sk-demo-key-12345

# --- Backend Python ---
PYTHON_HOST=0.0.0.0
PORT=8001

# --- NCBI API Key (PubMed - opcional mas recomendado) ---
# Sem API key: até 10 req/s
# Com API key (gratuita): taxa maior e acesso prioritário
# Obtenha em: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# --- Semantic Scholar API Key (opcional) ---
# Sem chave: ~1 req/s (suficiente para uso normal)
# Com chave (gratuita): ~10 req/s e maior estabilidade
# Obtenha em: https://www.semanticscholar.org/product/api
S2_API_KEY=

# --- SerpAPI Key (Google Scholar - opcional) ---
# Sem chave: Google Scholar desativado (retorna lista vazia)
# Plano gratuito: 100 buscas/mês · Pago: a partir de ~$50/mês
# Obtenha em: https://serpapi.com/manage-api-key
SERPAPI_KEY=

# --- Scrapers ---
# Timeout para requisições HTTP (segundos)
HTTP_TIMEOUT=30

# --- Cache ---
# O cache é em memória (TTL configurado no código):
# - cache_curto: 5 minutos
# - cache_medio: 1 hora (buscas)
# - cache_longo: 24 horas (listas estáticas como PCDTs)

