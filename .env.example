# ===========================================
# CONFIGURAÇÕES PARA API DE PESQUISA EM SAÚDE
# ===========================================

# --- Supabase ---
# Crie um projeto em https://supabase.com e cole as credenciais abaixo
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-service-role

# --- Backend Python ---
PYTHON_HOST=0.0.0.0
PYTHON_PORT=8000

# --- Backend Node.js ---
NODE_PORT=3000

# --- Scrapers ---
# Timeout para requisições HTTP (segundos)
HTTP_TIMEOUT=30

# User-Agent para scrapers
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# --- Cache ---
# TTL do cache de buscas em horas
CACHE_TTL_HOURS=24

# --- Prioridade de Fontes ---
# Fontes são priorizadas automaticamente:
# 1. Ministério da Saúde (PCDT, BVS, ANVISA)
# 2. Sociedades médicas (SBMFC, SBP, SBPT, SBC)
# 3. Bases científicas (SciELO, LILACS, PubMed)
# 4. Hospitais de referência
